# Open WebUI — connect to a LOCAL model served by Ollama on another server.
# Copy to .env:  cp .env.local.example .env
#
# This profile is for running models hosted on dev-005 (192.168.100.165:11434).
# It works alongside (or instead of) an external OpenAI-compatible API.

# Enable Ollama backend
ENABLE_OLLAMA_API=true
OLLAMA_BASE_URL=http://192.168.100.165:11434

# (Optional) Keep also an external OpenAI-compatible API (DeepSeek). Comment out
# the next two lines if you want LOCAL ONLY.
OPENAI_API_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Notes -------------------------------------------------------------------
# Ollama on dev-005 must listen on 0.0.0.0:11434 (verified).
# In Open WebUI you will see all `ollama list` models in the model picker, e.g.:
#   glm-uncensored:latest                        (~73 GB, 110B Q4_K_M)
#   gurubot/GLM-4.5-Air-Derestricted:Q4_K_M      (~73 GB, 110B)
#   dolphin-mixtral:8x22b-v2.9-q3_K_M            (uncensored MoE)
# Pull more with:  ollama pull <name>   (on dev-005)
