# Copy to .env:  cp .env.example .env

# Encrypts the repository contents. Losing this passphrase = losing every backup.
KOPIA_REPOSITORY_PASSWORD=

# Web UI credentials (port 51515).
KOPIA_SERVER_USERNAME=admin
KOPIA_SERVER_PASSWORD=

# Host path for the repository. Must live on a different disk than the source data.
KOPIA_REPO_PATH=/mnt/backup-hdd/kopia-repo

TZ=America/Lima
