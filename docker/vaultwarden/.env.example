# Copy to .env:  cp .env.example .env

# Public URL where Vaultwarden will be reachable. Required for WebAuthn / push.
DOMAIN=http://192.168.100.142:8003

# Argon2 hash of the admin panel password. Leave empty to disable the panel.
# Generate with: docker run --rm -it vaultwarden/server /vaultwarden hash
ADMIN_TOKEN=

# Set to false after creating the initial user.
SIGNUPS_ALLOWED=true

INVITATIONS_ALLOWED=false
