# Copy to .env:  cp .env.example .env

# Values come from the Hub UI: "Add System" dialog shows the exact snippet.

# Hub SSH public key. Full ssh-ed25519 line, quoted because it contains spaces.
HUB_KEY="ssh-ed25519 AAAA..."

# Per-agent registration token emitted by the Hub.
HUB_TOKEN=

# Hub base URL reachable from this host.
HUB_URL=http://192.168.100.142:9000
