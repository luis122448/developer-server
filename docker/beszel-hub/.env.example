# Copy to .env:  cp .env.example .env

# This stack has no required environment variables. Beszel Hub initializes
# itself on first boot and generates its own SSH keypair. The first user
# that registers via the web UI becomes the admin.
#
# Optional knobs (uncomment to use):
#
# Disable open registration after the admin account is created.
# DISABLE_PASSWORD_AUTH=false
#
# Public URL where the Hub is reachable; used by alert links and OAuth.
# APP_URL=http://192.168.100.142:9000
